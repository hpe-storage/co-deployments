{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "hpe-cosi-driver schema",
  "description": "This document validates the schema for a hpe-cosi-driver Helm chart",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "fullnameOverride":{
      "type": "string",
      "maxLength": 128
    },
    "componentName": {
      "type": "string",
      "maxLength": 128
    },
    "deployment": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "maxLength": 128
        }
      },
      "required": [ "name" ]
    },
    "regSecretName": {
      "type": "string"
    },
    "podEvictionToleration": {
      "type": "integer"
    },
    "containers": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cosiDriver": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "image": {
              "type": "string",
              "maxLength": 128
            },
            "name": {
              "type": "string",
              "maxLength": 128
            },
            "imagePullPolicy": {
              "type": "string",
              "pattern": "^(Always|Never|IfNotPresent)$"
            }
          }
        },
        "sideCar": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "image": {
              "type": "string",
              "maxLength": 128
            },
            "name": {
              "type": "string",
              "maxLength": 128
            },
            "imagePullPolicy": {
              "type": "string",
              "pattern": "^(Always|Never|IfNotPresent)$"
            }
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "title": "resource requests and limits",
      "additionalProperties": false,
      "description": "See https://kubernetes.io/docs/concepts/configuration/manage-resources-containers/",
      "properties": {
        "limits": {
          "type": "object",
          "title": "resource limits",
          "default": {}
        },
        "requests": {
          "type": "object",
          "title": "resource requests",
          "default": {}
        }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "title": "Pod-level security context",
      "description": "Security context applied at the pod level. On OpenShift, leave runAsUser/runAsGroup/fsGroup unset to let the platform assign from namespace ranges.",
      "additionalProperties": true,
      "properties": {
        "runAsNonRoot": {
          "type": "boolean"
        },
        "runAsUser": {
          "type": "integer"
        },
        "runAsGroup": {
          "type": "integer"
        },
        "fsGroup": {
          "type": "integer"
        }
      }
    },
    "containerSecurityContext": {
      "type": "object",
      "title": "Container-level security context",
      "description": "Security context applied to each container. Defaults satisfy OpenShift restricted-v2 SCC.",
      "additionalProperties": true,
      "properties": {
        "allowPrivilegeEscalation": {
          "type": "boolean"
        },
        "readOnlyRootFilesystem": {
          "type": "boolean"
        },
        "runAsNonRoot": {
          "type": "boolean"
        },
        "capabilities": {
          "type": "object",
          "properties": {
            "drop": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "seccompProfile": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "pattern": "^(RuntimeDefault|Localhost|Unconfined)$"
            }
          }
        }
      }
    }
  },
  "required": [
    "deployment",
    "containers"
  ]
}
